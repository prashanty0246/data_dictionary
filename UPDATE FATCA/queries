  INSERT_FATCA_DECLARATION_TABLE: `INSERT INTO "FATCA_DECLARATION_TABLE"
  (
    CUST_ID,
    IS_MODIFY_REQUEST,
    PREVIOUS_ANSWERS,
    NEW_ANSWERS,
    PREVIOUS_DATA,
    FREE_CODE_18,
    FREE_CODE_21,
