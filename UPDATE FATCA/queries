    :R_CRE_ID,
    :R_MOD_TIME,
    :R_MOD_ID
  )`,

  GET_MOBILENO_EMAIL_QUERY: `SELECT 
  DISTINCT (
          SELECT 
            email 
          FROM 
            crmuser.phoneemail 
          where 
            preferredflag = 'Y' 
            and rownum < 2 
            AND orgkey = e1.orgkey 
            AND phoneoremail = 'EMAIL'
        ) EMAIL, 
        (
          SELECT 
            phonenolocalcode 
          FROM 
            crmuser.phoneemail 
          where 
            preferredflag = 'Y' 
            and rownum < 2 
            AND orgkey = e1.orgkey 
            AND phoneoremail = 'PHONE'
        ) PHONE 
  FROM 
    crmuser.phoneemail e1 
  WHERE 
    orgkey = :CifID`,
}
